<!doctype html>
<html lang="en" class="h-full">
<head>
<meta charset="utf-8">
<title>{{.Title}}</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<script src="https://cdn.tailwindcss.com?plugins=typography"></script>
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/dompurify@3/dist/purify.min.js"></script>
</head>
<body class="h-full bg-slate-100 text-slate-900">
  <div class="mx-auto flex h-full max-w-3xl flex-col p-4">
    <header class="mb-4 flex items-center justify-between">
      <h1 class="text-lg font-semibold">{{.Title}}</h1>
    </header>

    <div id="log" class="flex-1 space-y-3 overflow-y-auto rounded-2xl bg-white p-4 shadow-sm ring-1 ring-slate-200"></div>

    <form id="form" class="mt-4 flex gap-2">
      <input type="file" id="file" accept=".txt,.md,.markdown,text/plain,text/markdown" class="hidden">
      <button
        type="button"
        id="attach"
        title="Upload a .txt or .md file to the document collection"
        class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-slate-300 bg-white text-slate-600 shadow-sm transition hover:bg-slate-50 disabled:cursor-wait disabled:opacity-50"
        aria-label="Attach file"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21.44 11.05 12.25 20.24a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/>
        </svg>
      </button>
      <button
        type="button"
        id="attachImage"
        title="Upload an image with a description"
        class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-slate-300 bg-white text-slate-600 shadow-sm transition hover:bg-slate-50 disabled:cursor-wait disabled:opacity-50"
        aria-label="Attach image"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
      </button>
      <input
        type="text"
        id="input"
        autocomplete="off"
        placeholder="Ask a question…"
        autofocus
        class="flex-1 rounded-full border border-slate-300 bg-white px-4 py-3 text-base shadow-sm outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500"
      >
      <button
        type="submit"
        id="send"
        class="rounded-full bg-blue-600 px-5 py-3 font-medium text-white shadow-sm transition hover:bg-blue-700 disabled:cursor-wait disabled:opacity-50"
      >Send</button>
    </form>
  </div>

  <dialog id="imageDialog" class="rounded-2xl p-0 backdrop:bg-slate-900/40">
    <form id="imageForm" class="flex w-[28rem] max-w-[90vw] flex-col gap-3 p-5">
      <h2 class="text-base font-semibold text-slate-900">Add an image</h2>
      <label class="text-xs font-medium text-slate-600">
        Image file
        <input
          type="file"
          id="imageFile"
          accept=".png,.jpg,.jpeg,.webp,.gif,image/png,image/jpeg,image/webp,image/gif"
          required
          class="mt-1 block w-full text-sm text-slate-700 file:mr-3 file:rounded-full file:border-0 file:bg-slate-100 file:px-3 file:py-1.5 file:text-xs file:font-medium hover:file:bg-slate-200"
        >
      </label>
      <label class="text-xs font-medium text-slate-600">
        <span class="flex items-center justify-between">
          <span>Description</span>
          {{if .CaptionEnabled}}
          <button
            type="button"
            id="autoCaption"
            class="rounded-full bg-slate-100 px-3 py-1 text-[11px] font-medium text-slate-700 hover:bg-slate-200 disabled:cursor-wait disabled:opacity-50"
            title="Generate a description from the image using the vision model"
          >✨ Auto-caption</button>
          {{end}}
        </span>
        <textarea
          id="imageDescription"
          rows="4"
          required
          placeholder="Describe what's in the image so it can be retrieved later."
          class="mt-1 block w-full resize-none rounded-lg border border-slate-300 bg-white p-2 text-sm text-slate-900 outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500"
        ></textarea>
      </label>
      <div class="mt-1 flex justify-end gap-2">
        <button
          type="button"
          id="imageCancel"
          class="rounded-full px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-100"
        >Cancel</button>
        <button
          type="submit"
          id="imageSubmit"
          class="rounded-full bg-blue-600 px-4 py-2 text-sm font-medium text-white shadow-sm transition hover:bg-blue-700 disabled:cursor-wait disabled:opacity-50"
        >Save</button>
      </div>
    </form>
  </dialog>

<script>
  const log = document.getElementById("log");
  const form = document.getElementById("form");
  const input = document.getElementById("input");
  const send = document.getElementById("send");
  const attach = document.getElementById("attach");
  const fileInput = document.getElementById("file");
  const attachImage = document.getElementById("attachImage");
  const imageDialog = document.getElementById("imageDialog");
  const imageForm = document.getElementById("imageForm");
  const imageFile = document.getElementById("imageFile");
  const imageDescription = document.getElementById("imageDescription");
  const imageCancel = document.getElementById("imageCancel");
  const imageSubmit = document.getElementById("imageSubmit");
  const history = [];

  // Render a centered, italic system notice — used for upload status
  // and other out-of-band events that aren't part of the chat
  // history. Returns the inner text node so callers can update its
  // content (e.g. "uploading…" → "✅ added").
  function renderNotice(text, tone = "info") {
    const row = document.createElement("div");
    row.className = "flex justify-center";

    const palette = {
      info:    "bg-slate-100 text-slate-600 ring-slate-200",
      success: "bg-emerald-50 text-emerald-700 ring-emerald-200",
      error:   "bg-rose-50 text-rose-700 ring-rose-200",
    };
    const note = document.createElement("div");
    note.className =
      "max-w-[90%] rounded-full px-4 py-1.5 text-xs italic ring-1 " +
      (palette[tone] || palette.info);
    note.textContent = text;

    row.appendChild(note);
    log.appendChild(row);
    log.scrollTop = log.scrollHeight;
    return note;
  }

  // Configure marked once. GFM is on for tables/strikethrough; breaks
  // turns single newlines into <br> so chat-style replies render the
  // way users typed them.
  marked.setOptions({ gfm: true, breaks: true });

  // Render untrusted markdown from the model into sanitized HTML.
  // DOMPurify drops scripts, event handlers, and other XSS vectors
  // before the result is inserted into the DOM.
  function renderMarkdown(text) {
    return DOMPurify.sanitize(marked.parse(text || ""));
  }

  // Render a chat bubble for the given role and return the inner
  // node that streaming callers should keep updating. User messages
  // stay as plain text (we trust the user, but they didn't ask for
  // markdown either); assistant messages render as sanitized
  // markdown via setMarkdown().
  function render(role, content) {
    const isUser = role === "user";

    const row = document.createElement("div");
    row.className = "flex " + (isUser ? "justify-end" : "justify-start");

    const bubble = document.createElement("div");
    if (isUser) {
      bubble.className = "max-w-[80%] whitespace-pre-wrap rounded-2xl rounded-br-sm bg-blue-600 px-4 py-2 text-sm text-white shadow-sm";
      bubble.textContent = content;
    } else {
      bubble.className = "prose prose-sm max-w-[80%] rounded-2xl rounded-bl-sm bg-slate-200 px-4 py-2 text-slate-900 shadow-sm prose-p:my-1 prose-headings:my-2 prose-pre:my-2 prose-ul:my-1 prose-ol:my-1";
      bubble.innerHTML = renderMarkdown(content);
    }
    // Helper attached to the bubble so callers don't have to know
    // which role it is — they just push text in.
    bubble.setMarkdown = (text) => {
      if (isUser) bubble.textContent = text;
      else bubble.innerHTML = renderMarkdown(text);
    };

    row.appendChild(bubble);
    log.appendChild(row);
    log.scrollTop = log.scrollHeight;
    return bubble;
  }

  // A small three-dot pulse used while we wait for the first token.
  function renderTyping() {
    const row = document.createElement("div");
    row.className = "flex justify-start";

    const bubble = document.createElement("div");
    bubble.className = "rounded-2xl rounded-bl-sm bg-slate-200 px-4 py-3 shadow-sm";

    const dots = document.createElement("div");
    dots.className = "flex gap-1";
    for (let i = 0; i < 3; i++) {
      const d = document.createElement("span");
      d.className = "h-2 w-2 animate-bounce rounded-full bg-slate-500";
      d.style.animationDelay = `${i * 0.15}s`;
      dots.appendChild(d);
    }

    bubble.appendChild(dots);
    row.appendChild(bubble);
    log.appendChild(row);
    log.scrollTop = log.scrollHeight;
    return { row, bubble };
  }

  attach.addEventListener("click", () => fileInput.click());

  // Image upload — opens a small dialog so the user can pick an image
  // and write a description in one step. The description is what gets
  // embedded; the image itself is just stored for later display.
  attachImage.addEventListener("click", () => {
    imageForm.reset();
    imageDialog.showModal();
    imageDescription.focus();
  });
  imageCancel.addEventListener("click", () => imageDialog.close());

  // Auto-caption — only present when the server has a VISION_MODEL
  // configured. Sends the chosen image to /api/caption and pre-fills
  // the description textarea with the model's reply. The user reviews
  // and edits before saving, so a hallucinated caption never makes it
  // into the vector store unchanged.
  const autoCaption = document.getElementById("autoCaption");
  if (autoCaption) {
    autoCaption.addEventListener("click", async () => {
      const file = imageFile.files && imageFile.files[0];
      if (!file) {
        imageFile.focus();
        return;
      }
      const original = autoCaption.textContent;
      autoCaption.disabled = true;
      autoCaption.textContent = "captioning…";
      try {
        const body = new FormData();
        body.append("image", file);
        const res = await fetch("/api/caption", { method: "POST", body });
        if (!res.ok) {
          const err = (await res.text()).trim();
          alert("Caption failed: " + (err || res.statusText));
          return;
        }
        const data = await res.json();
        imageDescription.value = data.description || "";
        imageDescription.focus();
      } catch (err) {
        alert("Caption failed: " + err);
      } finally {
        autoCaption.disabled = false;
        autoCaption.textContent = original;
      }
    });
  }

  imageForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    const file = imageFile.files && imageFile.files[0];
    const description = imageDescription.value.trim();
    if (!file || !description) return;

    imageSubmit.disabled = true;
    const notice = renderNotice(`Uploading ${file.name}…`, "info");

    try {
      const body = new FormData();
      body.append("image", file);
      body.append("description", description);

      const res = await fetch("/api/upload/image", { method: "POST", body });

      if (!res.ok) {
        const err = (await res.text()).trim();
        notice.textContent = `❌ ${file.name}: ${err || res.statusText}`;
        notice.parentElement.querySelector("div").className =
          "max-w-[90%] rounded-full px-4 py-1.5 text-xs italic ring-1 bg-rose-50 text-rose-700 ring-rose-200";
        return;
      }
      const data = await res.json();
      notice.textContent =
        `✅ Added image "${data.source}" · ${data.chunks} chunk${data.chunks === 1 ? "" : "s"} · ${data.bytes} bytes`;
      notice.parentElement.querySelector("div").className =
        "max-w-[90%] rounded-full px-4 py-1.5 text-xs italic ring-1 bg-emerald-50 text-emerald-700 ring-emerald-200";
      imageDialog.close();
    } catch (err) {
      notice.textContent = `❌ ${file.name}: ${err}`;
      notice.parentElement.querySelector("div").className =
        "max-w-[90%] rounded-full px-4 py-1.5 text-xs italic ring-1 bg-rose-50 text-rose-700 ring-rose-200";
    } finally {
      imageSubmit.disabled = false;
      input.focus();
    }
  });

  fileInput.addEventListener("change", async () => {
    const file = fileInput.files && fileInput.files[0];
    if (!file) return;
    // Reset so picking the same file twice still fires "change".
    fileInput.value = "";

    const notice = renderNotice(`Uploading ${file.name}…`, "info");
    attach.disabled = true;
    send.disabled = true;

    try {
      const body = new FormData();
      body.append("file", file);

      const res = await fetch("/api/upload", { method: "POST", body });

      if (!res.ok) {
        const err = (await res.text()).trim();
        notice.textContent = `❌ ${file.name}: ${err || res.statusText}`;
        notice.parentElement.querySelector("div").className =
          "max-w-[90%] rounded-full px-4 py-1.5 text-xs italic ring-1 bg-rose-50 text-rose-700 ring-rose-200";
        return;
      }
      const data = await res.json();
      notice.textContent =
        `✅ Added "${data.source}" to the collection · ${data.chunks} chunk${data.chunks === 1 ? "" : "s"} · ${data.bytes} bytes`;
      notice.parentElement.querySelector("div").className =
        "max-w-[90%] rounded-full px-4 py-1.5 text-xs italic ring-1 bg-emerald-50 text-emerald-700 ring-emerald-200";
    } catch (err) {
      notice.textContent = `❌ ${file.name}: ${err}`;
      notice.parentElement.querySelector("div").className =
        "max-w-[90%] rounded-full px-4 py-1.5 text-xs italic ring-1 bg-rose-50 text-rose-700 ring-rose-200";
    } finally {
      attach.disabled = false;
      send.disabled = false;
      input.focus();
    }
  });

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const text = input.value.trim();
    if (!text) return;
    input.value = "";
    send.disabled = true;

    history.push({ role: "user", content: text });
    render("user", text);
    const typing = renderTyping();
    let pending = null;

    function ensureBubble() {
      if (pending) return pending;
      typing.row.remove();
      pending = render("assistant", "");
      return pending;
    }

    try {
      const res = await fetch("/api/chat/stream", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ messages: history }),
      });
      if (!res.ok || !res.body) {
        const err = await res.text();
        ensureBubble().setMarkdown("error: " + err);
        history.pop();
        return;
      }

      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let buffer = "";
      let assembled = "";
      let errored = null;

      // SSE events are delimited by a blank line ("\n\n"). Each event
      // is one or more "field: value" lines; here we only care about
      // the "event:" type and the "data:" payload (JSON-encoded
      // string).
      while (true) {
        const { value, done } = await reader.read();
        if (done) break;
        buffer += decoder.decode(value, { stream: true });

        let sep;
        while ((sep = buffer.indexOf("\n\n")) !== -1) {
          const raw = buffer.slice(0, sep);
          buffer = buffer.slice(sep + 2);

          let evt = "message", data = "";
          for (const line of raw.split("\n")) {
            if (line.startsWith("event:")) evt = line.slice(6).trim();
            else if (line.startsWith("data:")) data += line.slice(5).trim();
          }
          let payload = "";
          try { payload = JSON.parse(data); } catch { payload = data; }

          if (evt === "delta") {
            assembled += payload;
            ensureBubble().setMarkdown(assembled);
            log.scrollTop = log.scrollHeight;
          } else if (evt === "error") {
            errored = payload || "stream error";
          }
        }
      }

      if (errored) {
        ensureBubble().setMarkdown("error: " + errored);
        history.pop();
      } else if (assembled) {
        history.push({ role: "assistant", content: assembled });
      } else {
        ensureBubble().setMarkdown("(no response)");
        history.pop();
      }
    } catch (err) {
      ensureBubble().setMarkdown("error: " + err);
      history.pop();
    } finally {
      // If the typing indicator is still on screen (e.g. fetch threw
      // before any event), drop it so the UI doesn't get stuck.
      if (typing.row.isConnected) typing.row.remove();
      send.disabled = false;
      input.focus();
    }
  });
</script>
</body>
</html>
